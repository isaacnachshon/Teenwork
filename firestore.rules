rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isLoggedIn() && getUserRole() == 'admin';
    }

    function isEmployer() {
      return isLoggedIn() && getUserRole() == 'employer';
    }

    function isTeen() {
      return isLoggedIn() && getUserRole() == 'teen';
    }

    function isOwnUser(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isLoggedIn() && (isAdmin() || isOwnUser(userId));
      allow create: if isOwnUser(userId);
      allow update: if isAdmin() || isOwnUser(userId);
      allow delete: if isAdmin();
    }

    match /companies/{companyId} {
      allow read: if isLoggedIn();
      allow create: if isEmployer() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAdmin() || (isEmployer() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if isLoggedIn();
      allow create: if isEmployer() && request.resource.data.employerId == request.auth.uid;
      allow update: if isAdmin() || (isEmployer() && resource.data.employerId == request.auth.uid);
      allow delete: if isAdmin() || (isEmployer() && resource.data.employerId == request.auth.uid);
    }

    match /applications/{appId} {
      allow read: if isAdmin()
        || (isTeen() && resource.data.applicantId == request.auth.uid)
        || (isEmployer() && resource.data.employerId == request.auth.uid);
      allow create: if isTeen() && request.resource.data.applicantId == request.auth.uid;
      allow update: if isAdmin() || (isEmployer() && resource.data.employerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isLoggedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isLoggedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAdmin() || (isLoggedIn() && resource.data.senderId == request.auth.uid);
      allow delete: if isAdmin() || (isLoggedIn() && resource.data.senderId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin() || (isLoggedIn() && request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (isLoggedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
  }
}
